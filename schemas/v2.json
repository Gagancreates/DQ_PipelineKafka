{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Order Schema v2",
  "description": "Adds mandatory currency field. Restricts currencies to USD, EUR, GBP. Caps amount at 1,000,000.",
  "type": "object",
  "required": ["order_id", "customer_id", "amount", "order_date", "currency", "schema_version"],
  "additionalProperties": true,
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "v2"
    },
    "order_id": {
      "type": "string",
      "minLength": 1
    },
    "customer_id": {
      "type": "string",
      "minLength": 1
    },
    "amount": {
      "type": "number"
    },
    "order_date": {
      "type": "string",
      "minLength": 1
    },
    "currency": {
      "type": "string",
      "minLength": 1
    }
  },
  "business_rules": {
    "order_id_pattern": "^ORD-\\d{4}-\\d{3,}$",
    "amount_min": 0,
    "amount_max": 1000000,
    "order_date_not_future": true,
    "allowed_currencies": ["USD", "EUR", "GBP"]
  }
}
