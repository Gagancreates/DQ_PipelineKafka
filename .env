# Kafka
KAFKA_BOOTSTRAP_SERVERS=kafka:9092

# Topics
TOPIC_RAW_ORDERS=raw.orders
TOPIC_VALID_ORDERS=valid.orders
TOPIC_DLQ=invalid.orders.dlq
TOPIC_SCHEMA_UPDATES=schema.updates

# Consumer Groups
CONSUMER_GROUP_VALIDATOR=dq-validator
CONSUMER_GROUP_DLQ_PROCESSOR=dq-dlq-processor

# Producer
PRODUCE_INTERVAL_MS=800

# Validator
MAX_CONCURRENT_VALIDATIONS=10

# API
API_HOST=0.0.0.0
API_PORT=8000
